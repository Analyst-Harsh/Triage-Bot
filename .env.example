# Copy this file to .env and fill in real values. Never commit .env itself --
# it's gitignored, and Claude Code is configured to refuse reading it
# (see .claude/settings.json and docs/agent/security.md).
#
# Every variable below is read by config/settings.py's Settings class --
# that file is the single source of truth; keep this list in sync with it.

# --- Secrets (required for the features that use them) ---------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=
TAVILY_API_KEY=
E2B_API_KEY=

# --- Ops-tunable values (optional -- shown with their code defaults) -------
# LLM_REQUEST_TIMEOUT_SECONDS=30.0
# LLM_MAX_RETRIES=2

# E2B_SANDBOX_SESSION_TIMEOUT_SECONDS=900.0
# E2B_INSTALL_TIMEOUT_SECONDS=300.0
# E2B_TEST_COMMAND_TIMEOUT_SECONDS=180.0
# E2B_MAX_BILLED_SECONDS_PER_RUN=600.0
# E2B_COST_PER_SECOND_USD=0.000028
# E2B_RESTRICT_NETWORK=true

# GitHub's officially-hosted remote MCP server (streamable-HTTP transport).
# GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# DocMind-MCP: a sibling project whose exact launch command isn't finalized
# yet. Leave unset -- the Researcher degrades gracefully without it.
# DOCMIND_MCP_COMMAND=
# DOCMIND_MCP_ARGS=
# DOCMIND_MCP_CWD=

# Bounds context/cost blowup from a single huge file or webpage returned by
# an untrusted research tool call.
# RESEARCHER_TOOL_OUTPUT_MAX_CHARS=8000
# DRAFTER_FILE_READ_MAX_CHARS=16000
# DRAFTER_TEST_LOG_SUCCESS_MAX_CHARS=500
# DRAFTER_TEST_LOG_FAILURE_MAX_CHARS=3000
